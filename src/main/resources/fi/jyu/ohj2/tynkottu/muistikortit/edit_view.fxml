<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<HBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="fi.jyu.ohj2.tynkottu.muistikortit.EditViewController">
   <children>
      <VBox prefHeight="200.0" prefWidth="100.0">
         <children>
            <TextField fx:id="deckTitleField" />
            <TextArea fx:id="deckDescriptionArea" prefHeight="200.0" prefWidth="200.0" VBox.vgrow="ALWAYS" />
            <Label fx:id="cardCountLabel" text="Label" textFill="#535353" />
         </children>
      </VBox>
      <VBox prefHeight="200.0" prefWidth="100.0" HBox.hgrow="ALWAYS">
         <children>
            <VBox prefHeight="200.0" prefWidth="100.0" VBox.vgrow="ALWAYS">
               <children>
                  <TextField fx:id="cardTitleField" />
                  <TextArea fx:id="cardDescriptionArea" prefHeight="200.0" prefWidth="200.0" />
               </children>
            </VBox>
            <TableView fx:id="cardTable" prefHeight="200.0" prefWidth="200.0" />
         </children>
      </VBox>
      <ToolBar orientation="VERTICAL" prefHeight="40.0">
        <items>
            <Button fx:id="cardDeleteButton" mnemonicParsing="false" onAction="#handleCardDelete" text="Delete" />
            <Button fx:id="cardCreateButton" mnemonicParsing="false" onAction="#handleCardCreate" text="Create" />
        </items>
      </ToolBar>
   </children>
</HBox>
